# Base RPC endpoint (default: public Base mainnet node)
# For higher rate limits, use Alchemy/Infura/Quicknode:
#   https://www.alchemy.com/  or  https://www.quicknode.com/
BASE_RPC_URL=https://mainnet.base.org

# Port for the MCP HTTP server
PORT=8788

# No API key required — holder/deployer data comes from Blockscout (base.blockscout.com), which is free.
