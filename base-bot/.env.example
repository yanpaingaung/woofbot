# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Voyage AI (embeddings) ─────────────────────────────────────────────────────
# Anthropic's recommended embedding provider. Free: 200M tokens/month.
# Get a free key at: https://dash.voyageai.com
# Model: voyage-3 (1024-dim). No paid plan needed for this bot's volume.
VOYAGE_API_KEY=pa-...

# ── Supabase ───────────────────────────────────────────────────────────────────
# Project URL from Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
# Service role key (not anon) — Project Settings → API → service_role
SUPABASE_SERVICE_KEY=eyJ...

# ── MCP servers ────────────────────────────────────────────────────────────────
BASE_ANALYTICS_MCP_URL=http://localhost:8788/mcp
# BASE_MCP_URL=https://mcp.base.org/mcp   # Coinbase public Base MCP (optional)

# ── X (Twitter) OAuth 1.0a ─────────────────────────────────────────────────────
X_APP_KEY=...
X_APP_SECRET=...
X_ACCESS_TOKEN=...-...
X_ACCESS_SECRET=...
X_BOT_USER_ID=...

# ── Bot behaviour ──────────────────────────────────────────────────────────────
DRY_RUN=true
POLL_INTERVAL_MS=300000
DAILY_RATE_LIMIT=20
CACHE_TTL_SECONDS=300
