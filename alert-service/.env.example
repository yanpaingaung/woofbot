# --- Shared credentials (same values as base-bot) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

X_APP_KEY=...
X_APP_SECRET=...
X_ACCESS_TOKEN=...-...
X_ACCESS_SECRET=...

# --- From base-analytics-mcp (reuse existing keys) ---
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/<your-alchemy-key>
BASESCAN_API_KEY=<your-basescan-key>
DUNE_API_KEY=<your-dune-key>
TAVILY_API_KEY=<your-tavily-key>

# Alert thresholds
WHALE_USD_THRESHOLD=50000
NEW_TOKEN_LIQUIDITY_MIN=10000
TRENDING_VOLUME_CHANGE_PCT=50

# Comma-separated wallet addresses to track (also manageable via DB)
TRACKED_WALLETS=0x...,0x...

# Poll intervals in milliseconds
WHALE_POLL_MS=60000
WALLET_POLL_MS=90000
TOKEN_POLL_MS=300000
POOL_POLL_MS=600000

# Set to false to actually post tweets (defaults to true = dry run)
ALERT_DRY_RUN=true

# Hours before a duplicate alert is allowed again
DEDUP_TTL_HOURS=24
